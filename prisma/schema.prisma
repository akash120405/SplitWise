generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SplitType {
  EQUAL
  UNEQUAL
  PERCENTAGE
  SHARE
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groupMembers GroupMember[]
  expensesPaid Expense[]     @relation("ExpensePayer")

  settlementsSent     Settlement[] @relation("Payer")
  settlementsReceived Settlement[] @relation("Receiver")

  expenseParticipations ExpenseParticipant[]
  messages              ExpenseMessage[]
}

model Group {
  id   String @id @default(uuid())
  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  GroupMember[]
  expenses Expense[]
}

model GroupMember {
  id String @id @default(uuid())

  groupId String
  userId  String

  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  isActive Boolean @default(true)

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([groupId, userId])
}

model Expense {
  id String @id @default(uuid())

  title  String
  amount Decimal @db.Decimal(10, 2)

  splitType SplitType

  groupId  String
  paidById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group  Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy User  @relation("ExpensePayer", fields: [paidById], references: [id])

  anomalies Anomaly[] @relation("ExpenseAnomalies")

  participants ExpenseParticipant[]
  messages     ExpenseMessage[]
}

model ExpenseParticipant {
  id String @id @default(uuid())

  expenseId String
  userId    String

  owedAmount Decimal @db.Decimal(10, 2)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
}

model Settlement {
  id String @id @default(uuid())

  payerId    String
  receiverId String

  amount Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  payer    User @relation("Payer", fields: [payerId], references: [id])
  receiver User @relation("Receiver", fields: [receiverId], references: [id])
}

model Anomaly {
  id String @id @default(uuid())

  expenseId String?

  type     String
  severity String

  description String
  actionTaken String

  createdAt DateTime @default(now())

  expense Expense? @relation("ExpenseAnomalies", fields: [expenseId], references: [id])
}

model ExpenseMessage {
  id String @id @default(uuid())

  expenseId String
  userId    String

  message String

  createdAt DateTime @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
}
